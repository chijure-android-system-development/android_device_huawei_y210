+// BT.601 NV21 (Y plane + VU interleaved) → RGB565.
+// Processes two horizontally-adjacent pixels per iteration to share UV loads.
+static void convertNV21toRGB565(
+        const uint8_t* src, uint16_t* dst, int width, int height, int stride)
+{
+    const uint8_t* uvp = src + stride * height;
+    for (int y = 0; y < height; y++) {
+        const uint8_t* yrow = src + y * stride;
+        const uint8_t* uvrow = uvp + (y >> 1) * stride;
+        uint16_t* drow = dst + y * width;
+        for (int x = 0; x < width; x += 2) {
+            int v = (int)uvrow[x]     - 128;  // Cr (V first in NV21)
+            int u = (int)uvrow[x + 1] - 128;  // Cb
+            int rv = 409 * v, gu = 100 * u, gv = 208 * v, bu = 516 * u;
+            for (int p = 0; p < 2; p++) {
+                int c = (int)yrow[x + p] - 16;
+                int r = (298*c + rv       + 128) >> 8;
+                int g = (298*c - gu - gv  + 128) >> 8;
+                int b = (298*c       + bu + 128) >> 8;
+                r = r<0?0:r>255?255:r;
+                g = g<0?0:g>255?255:g;
+                b = b<0?0:b>255?255:b;
+                drow[x + p] = (uint16_t)(((r>>3)<<11)|((g>>2)<<5)|(b>>3));
+            }
+        }
+    }
+}
