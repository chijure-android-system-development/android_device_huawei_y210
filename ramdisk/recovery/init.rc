import /init.recovery.${ro.hardware}.rc

on early-init
    start ueventd
    mkdir /dev/log 0755 root root

on init
    #/* < DTS2011092300897 libeibei 20110923 begin */
    export PATH /sbin:/system/sbin:/system/bin:/system/xbin
    #/* DTS2011092300897 libeibei 20110923 end > */
    export ANDROID_ROOT /system
    export ANDROID_DATA /data
    # export EXTERNAL_STORAGE /sdcard
    export EXTERNAL_STORAGE /external_sd
    symlink /system/etc /etc
    
    mkdir /boot
    mkdir /recovery
    mkdir /system
    mkdir /data
    mkdir /cache
    mount tmpfs tmpfs /tmp
    chown root shell /tmp
    chmod 0775 /tmp

#/* < DTS2011092300897 libeibei 20110923 begin */
on emmc-fs
# mount mmc partitions
    wait /dev/block/mmcblk0p12
    mount ext4 /dev/block/mmcblk0p12 /system rw barrier=1

on fs
# mount mtd partitions
    mount yaffs2 mtd@system /system
#/* DTS2011092300897 libeibei 20110923 end > */
    
    # Create USB nodes if they don't exist
    mkdir -p /sys/class/android_usb/android0

    # Set USB configuration (default to mtp,adb)
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/idVendor 12d1
    write /sys/class/android_usb/android0/idProduct 1038
    write /sys/class/android_usb/android0/functions mtp,adb
    write /sys/class/android_usb/android0/iManufacturer HUAWEI
    write /sys/class/android_usb/android0/iProduct "Huawei Y210"
    write /sys/class/android_usb/android0/iSerial MSM7627A
    write /sys/class/android_usb/android0/enable 1

    # Fall back to usb_composite interface (old msm7x27a kernel)
    write /sys/class/usb_composite/adb/enable 1
    write /sys/class/usb_composite/mtp/enable 1
    write /sys/class/usb_composite/usb_mass_storage/enable 0
    write /sys/class/usb_composite/diag/enable 0
    write /sys/class/usb_composite/rndis/enable 0
    write /sys/class/usb_composite/rmnet/enable 0
    write /sys/class/usb_composite/modem/enable 0
    write /sys/class/usb_composite/nmea/enable 0

    # Evita que usb_autorun intente un ISO inexistente: apunta el LUN0 al external_sd
    write /sys/devices/platform/usb_mass_storage/lun0/file /dev/block/mmcblk0p1
    write /sys/devices/platform/usb_mass_storage/lun0/ro 0
    write /sys/devices/platform/usb_mass_storage/lun1/file ""
    write /sys/devices/platform/usb_mass_storage/lun2/file ""


on boot

    ifup lo
    hostname localhost
    domainname localdomain
    
    # Force start ADB for recovery
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/functions mtp,adb
    write /sys/class/android_usb/android0/enable 1
    setprop sys.usb.config mtp,adb
    setprop sys.usb.state mtp,adb

    # Ensure only ADB+MTP are active on composite driver too
    write /sys/class/usb_composite/adb/enable 1
    write /sys/class/usb_composite/mtp/enable 1
    write /sys/class/usb_composite/usb_mass_storage/enable 0
    write /sys/class/usb_composite/diag/enable 0
    write /sys/class/usb_composite/rndis/enable 0
    write /sys/class/usb_composite/rmnet/enable 0
    write /sys/class/usb_composite/modem/enable 0
    write /sys/class/usb_composite/nmea/enable 0

    # Refuerza la asignación de LUN para que el host no reciba un ISO vacío
    write /sys/devices/platform/usb_mass_storage/lun0/file /dev/block/mmcblk0p1
    write /sys/devices/platform/usb_mass_storage/lun0/ro 0
    write /sys/devices/platform/usb_mass_storage/lun1/file ""
    write /sys/devices/platform/usb_mass_storage/lun2/file ""

    start adbd
    setprop service.adb.root 1

    class_start default

on property:sys.powerctl=*
   powerctl ${sys.powerctl}

on property:sys.storage.ums_enabled=1
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/functions adb,mass_storage
    write /sys/class/android_usb/android0/enable 1

on property:sys.storage.ums_enabled=0
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/functions adb
    write /sys/class/android_usb/android0/enable 1

on property:sys.usb.config=none
    stop adbd
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/bDeviceClass 0

on property:sys.usb.config=mtp,adb
    stop adbd
    write /sys/class/android_usb/android0/enable 0
    write /sys/devices/platform/android_usb/usb_function_switch 130
    write /sys/class/android_usb/android0/functions ${sys.usb.config}
    write /sys/class/android_usb/android0/enable 1
    start adbd
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=adb
    stop adbd
    write /sys/class/android_usb/android0/enable 0
    write /sys/devices/platform/android_usb/usb_function_switch 2
    write /sys/class/android_usb/android0/functions ${sys.usb.config}
    write /sys/class/android_usb/android0/enable 1
    start adbd
    setprop sys.usb.state ${sys.usb.config}

service ueventd /sbin/ueventd
    critical

#/* <DTS2011092902032 sunwenyong 20110929 begin */
service charge	/sbin/charge
#/* DTS2011092902032 sunwenyong 20110929 end> */
service adbd /sbin/adbd recovery
    socket adbd stream 660 system system
    class core
    seclabel u:r:adbd:s0
    disabled

# Always start adbd on userdebug and eng builds
on property:ro.debuggable=1
    #write /sys/class/android_usb/android0/enable 1
    #start adbd
    setprop service.adb.root 1

# Restart adbd so it can run as root
on property:service.adb.root=1
    write /sys/class/android_usb/android0/enable 0
    restart adbd
    write /sys/class/android_usb/android0/enable 1

#/* < DTS2011110702064 libeibei 20111110 begin */
service recovery /sbin/sh /sbin/ncm.sh
	oneshot
#/* DTS2011110702064 libeibei 20111110 end > */